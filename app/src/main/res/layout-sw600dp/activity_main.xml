<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainlayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_inverseOnSurface"
    tools:context=".main.MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            android:id="@+id/toolbarlayout"
            layout="@layout/toolbar" />

        <LinearLayout
            android:id="@+id/app"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/md_theme_background"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/content_padding">

            <LinearLayout
                android:id="@+id/up"
                android:layout_width="match_parent"
                android:layout_height="@dimen/info_container_height"
                android:paddingTop="6dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/info_container_side_margin"
                    android:layout_marginEnd="@dimen/info_container_side_margin"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/DeviceImage"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/unknown" />

                    <FrameLayout
                        android:id="@+id/cv_info"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="@dimen/card_spacing"
                        android:animateLayoutChanges="true"
                        android:background="@drawable/card_background"
                        android:backgroundTint="@color/md_theme_inverseOnSurface"
                        android:clipToOutline="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:stateListAnimator="@animator/state_list_anim">

                        <LinearLayout
                            android:id="@+id/info_text"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="14dp"
                            android:gravity="left|center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginVertical="4dp"
                                android:gravity="center"
                                android:text="WINDOWS ON ARM"
                                android:textSize="@dimen/text_title"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/deviceName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left"
                                android:textSize="@dimen/text_label" />

                            <TextView
                                android:id="@+id/tv_ramvalue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left"
                                android:textSize="@dimen/text_label" />

                            <TextView
                                android:id="@+id/tv_panel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left"
                                android:textSize="@dimen/text_label"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tv_date"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left"
                                android:textSize="@dimen/text_label" />

                            <TextView
                                android:id="@+id/tv_slot"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left"
                                android:textSize="@dimen/text_label" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:id="@+id/guide"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="2dp"
                                    android:layout_weight="1"
                                    android:animateLayoutChanges="true"
                                    android:background="@drawable/card_background"
                                    android:backgroundTint="@color/md_theme_onPrimary"
                                    android:clickable="true"
                                    android:clipToOutline="true"
                                    android:focusable="true"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:minHeight="@dimen/chip_height"
                                    android:stateListAnimator="@animator/state_list_anim">

                                    <android.widget.TextView
                                        android:id="@+id/guide_text"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:autoSizeMaxTextSize="@dimen/text_header"
                                        android:autoSizeMinTextSize="10sp"
                                        android:autoSizeStepGranularity="1sp"
                                        android:autoSizeTextType="uniform"
                                        android:gravity="center"
                                        android:maxLines="1"
                                        android:paddingVertical="4dp"
                                        android:text="@string/guide"
                                        android:textStyle="bold" />
                                </FrameLayout>

                                <FrameLayout
                                    android:id="@+id/group"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="2dp"
                                    android:layout_weight="1"
                                    android:animateLayoutChanges="true"
                                    android:background="@drawable/card_background"
                                    android:backgroundTint="@color/md_theme_onPrimary"
                                    android:clickable="true"
                                    android:clipToOutline="true"
                                    android:focusable="true"
                                    android:foreground="?android:attr/selectableItemBackground"
                                    android:minHeight="@dimen/chip_height"
                                    android:stateListAnimator="@animator/state_list_anim">

                                    <android.widget.TextView
                                        android:id="@+id/group_text"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:autoSizeMaxTextSize="@dimen/text_header"
                                        android:autoSizeMinTextSize="10sp"
                                        android:autoSizeStepGranularity="1sp"
                                        android:autoSizeTextType="uniform"
                                        android:gravity="center"
                                        android:maxLines="1"
                                        android:paddingVertical="4dp"
                                        android:text="@string/group"
                                        android:textStyle="bold" />

                                </FrameLayout>

                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/appRight"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingBottom="6dp">

                <com.woa.helper.main.Button
                    android:id="@+id/backup"
                    style="@style/button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:image="@drawable/ic_disk"
                    app:subtitle="@string/backup_boot_subtitle"
                    app:title="@string/backup_boot_title" />

                <com.woa.helper.main.Button
                    android:id="@+id/mnt"
                    style="@style/button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:image="@drawable/mnt"
                    app:subtitle="@string/mnt_subtitle"
                    app:title="@string/mnt_title" />

                <com.woa.helper.main.Button
                    android:id="@+id/toolbox"
                    style="@style/button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:image="@drawable/toolbox"
                    app:subtitle="@string/toolbox_subtitle"
                    app:title="@string/toolbox_title" />

                <com.woa.helper.main.Button
                    android:id="@+id/quick_boot"
                    style="@style/button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:image="@drawable/ic_launcher_foreground"
                    app:subtitle="@string/quickboot_subtitle"
                    app:title="@string/quickboot_title" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <com.github.mmin18.widget.RealtimeBlurView
        android:id="@+id/blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:realtimeBlurRadius="10dp"
        app:realtimeOverlayColor="#80000000" />

</FrameLayout>
