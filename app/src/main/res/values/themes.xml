<resources>

    <style name="Theme.MyApplication" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorAccent">@color/md_theme_primary</item>
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="preferenceTheme">@style/PreferenceFragment.Material</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/md_theme_inverseOnSurface</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
    </style>

    <style name="button">
        <item name="android:stateListAnimator">@animator/state_list_anim</item>
        <item name="android:animateLayoutChanges">true</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="settingsButton">
        <item name="android:layout_margin">5dp</item>
    </style>

    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">@dimen/_13ssp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>